{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Purchase Order Material PUT Schema",
  "description": "JSON contract for updating Purchase Order Material data by uuidHeader. This endpoint supports header update, existing detail update by uuid, and new detail insertion when uuid is not provided.",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "List of Purchase Order Material records to be updated.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "header": {
            "type": "object",
            "description": "PO Material header section. uuidHeader is required for update.",
            "properties": {
              "uuidHeader": {
                "type": "string",
                "format": "uuid",
                "description": "Primary key for header update. Required. System will update data only if uuidHeader exists in database."
              },
              "supplierCode": {
                "type": "string",
                "maxLength": 50,
                "description": "Supplier code. Updateable."
              },
              "poDate": {
                "type": "string",
                "description": "PO date. Updateable. Expected format: DD-MM-YYYY."
              },
              "poNo": {
                "type": "string",
                "maxLength": 50,
                "description": "PO number. Not updateable, but must be sent with original value."
              },
              "etdActual": {
                "type": ["string", "null"],
                "description": "ETD Actual. Updateable. Can be null."
              },
              "eta": {
                "type": ["string", "null"],
                "description": "ETA. Updateable. Can be null."
              },
              "fc": {
                "type": "string",
                "maxLength": 15,
                "description": "PO type. Updateable."
              }
            },
            "required": [
              "uuidHeader",
              "supplierCode",
              "poDate",
              "poNo",
              "etdActual",
              "eta",
              "fc"
            ],
            "additionalProperties": false
          },
          "details": {
            "type": "array",
            "description": "Detail material lines. If uuid is provided, the detail will be updated. If uuid is not provided or empty, the detail will be added as a new item.",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "uuid": {
                  "type": ["string", "null"],
                  "format": "uuid",
                  "description": "Detail row key. If provided, update existing detail. If not provided or null, add as new detail."
                },
                "additionalRemarks": {
                  "type": ["string", "null"],
                  "description": "Additional remarks. Updateable. Can be null."
                },
                "orderNo": {
                  "type": "string",
                  "maxLength": 25,
                  "description": "Sales/Production order number. Updateable."
                },
                "itemCode": {
                  "type": "string",
                  "maxLength": 50,
                  "description": "Material item code. Updateable."
                },
                "vendorQty": {
                  "type": "number",
                  "description": "Vendor quantity. Updateable."
                },
                "vendorUnitCode": {
                  "type": "string",
                  "maxLength": 10,
                  "description": "Vendor unit code. Updateable."
                },
                "unitPrice": {
                  "type": "number",
                  "description": "Unit price. Updateable."
                },
                "currency": {
                  "type": "string",
                  "maxLength": 10,
                  "description": "Currency code. Updateable. Example: USD, IDR."
                },
                "lineItemNo": {
                  "type": "number",
                  "description": "Line item number on SAP. Updateable."
                }
              },
              "required": [
                "additionalRemarks",
                "orderNo",
                "itemCode",
                "vendorQty",
                "vendorUnitCode",
                "unitPrice",
                "currency",
                "lineItemNo"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "header",
          "details"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "data"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "data": [
        {
          "header": {
            "uuidHeader": "5e7b9981-ea4e-40fd-b133-498bc0af80c0",
            "supplierCode": "SUP-PIPE028",
            "poDate": "10-08-2026",
            "poNo": "PO/AND/003/2026",
            "etdActual": "10-08-2026",
            "eta": "25-09-2026",
            "fc": "POI"
          },
          "details": [
            {
              "uuid": "5a6515d6-4e45-4968-a13c-41a7c637c1cc",
              "additionalRemarks": "Update qty",
              "orderNo": "FG-RAK-0028",
              "itemCode": "HW-0018",
              "vendorQty": 400,
              "vendorUnitCode": "PCS",
              "unitPrice": 12000,
              "currency": "IDR",
              "lineItemNo": 102
            },
            {
              "additionalRemarks": "New Item (without uuid)",
              "orderNo": "FG-RAK-0038ADD",
              "itemCode": "HW-0030",
              "vendorQty": 1120,
              "vendorUnitCode": "PCE",
              "unitPrice": 5000,
              "currency": "IDR",
              "lineItemNo": 104
            }
          ]
        }
      ]
    }
  ]
}