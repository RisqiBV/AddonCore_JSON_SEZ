{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Purchase Order General PUT Schema",
  "description": "JSON contract for updating Purchase Order General data by uuidHeader. This endpoint supports header update, existing detail update by uuid, and new detail insertion when uuid is not provided.",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "List of Purchase Order General records to be updated.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "header": {
            "type": "object",
            "description": "PO header section. uuidHeader is required for update.",
            "properties": {
              "uuidHeader": {
                "type": "string",
                "format": "uuid",
                "description": "Primary key for header update. Required. System will update data only if uuidHeader exists in database."
              },
              "supplierCode": {
                "type": "string",
                "maxLength": 50,
                "description": "Supplier code. Updateable."
              },
              "poDate": {
                "type": "string",
                "description": "PO date. Updateable. Expected format: DD-MM-YYYY."
              },
              "poNo": {
                "type": "string",
                "maxLength": 50,
                "description": "PO number. Not updateable, but must be sent with original value."
              },
              "etdActual": {
                "type": ["string", "null"],
                "description": "ETD Actual. Updateable. Can be null."
              },
              "eta": {
                "type": ["string", "null"],
                "description": "ETA. Updateable. Can be null."
              },
              "fc": {
                "type": "string",
                "maxLength": 15,
                "enum": ["PO", "FOC"],
                "description": "PO type. Updateable. Allowed values: PO or FOC."
              }
            },
            "required": [
              "uuidHeader",
              "supplierCode",
              "poDate",
              "poNo",
              "etdActual",
              "eta",
              "fc"
            ],
            "additionalProperties": false
          },
          "details": {
            "type": "array",
            "description": "Detail item lines. If uuid is provided, the detail will be updated. If uuid is not provided or empty, the detail will be added as a new item.",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "uuid": {
                  "type": ["string", "null"],
                  "format": "uuid",
                  "description": "Detail row key. If provided, update existing detail. If not provided or null, add as new detail."
                },
                "additionalRemarks": {
                  "type": ["string", "null"],
                  "description": "Additional remarks. Updateable. Can be null."
                },
                "itemCode": {
                  "type": "string",
                  "maxLength": 50,
                  "description": "Material item code. Updateable."
                },
                "vendorQty": {
                  "type": "number",
                  "description": "Vendor quantity. Updateable. Decimal value."
                },
                "vendorUnitCode": {
                  "type": "string",
                  "maxLength": 10,
                  "description": "Vendor unit code. Updateable."
                },
                "unitPrice": {
                  "type": "number",
                  "description": "Unit price. Updateable. Decimal value."
                },
                "currency": {
                  "type": "string",
                  "maxLength": 10,
                  "description": "Currency code. Updateable. Example: USD, IDR."
                },
                "lineItemNo": {
                  "type": "number",
                  "description": "Line item number on SAP. Updateable."
                }
              },
              "required": [
                "additionalRemarks",
                "itemCode",
                "vendorQty",
                "vendorUnitCode",
                "unitPrice",
                "currency",
                "lineItemNo"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "header",
          "details"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "data"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "data": [
        {
          "header": {
            "uuidHeader": "d9610df4-b9e5-4bd5-96cc-2f6d6c6b4508",
            "supplierCode": "MSN-0015",
            "poDate": "10-08-2026",
            "poNo": "PO/KWL/004/2026",
            "etdActual": "10-08-2026",
            "eta": "10/09/2026",
            "fc": "PO"
          },
          "details": [
            {
              "uuid": "acd16dff-f938-4ab5-a1e6-51878dcede3a",
              "additionalRemarks": null,
              "itemCode": "RM-0011",
              "vendorQty": 150.5,
              "vendorUnitCode": "KGM",
              "unitPrice": 110,
              "currency": "USD",
              "lineItemNo": 100
            },
            {
              "additionalRemarks": null,
              "itemCode": "RM-0099",
              "vendorQty": 50,
              "vendorUnitCode": "KGM",
              "unitPrice": 200,
              "currency": "USD",
              "lineItemNo": 102
            }
          ]
        }
      ]
    }
  ]
}