{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Master PUT Schema",
  "description": "JSON contract for updating Customer Master data by uuid. This endpoint supports bulk update through data array.",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "List of customer master records to be updated.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Primary key for update. Required. System will update data only if uuid exists in database."
          },
          "customerCode": {
            "type": "string",
            "maxLength": 10,
            "description": "Customer code. Not updateable, but must be sent with original value."
          },
          "customerName": {
            "type": "string",
            "maxLength": 50,
            "description": "Customer name. Updateable."
          },
          "address": {
            "type": "string",
            "maxLength": 50,
            "description": "Customer address. Updateable."
          },
          "city": {
            "type": ["string", "null"],
            "maxLength": 50,
            "description": "City. Updateable."
          },
          "province": {
            "type": ["string", "null"],
            "maxLength": 50,
            "description": "Province or state. Updateable."
          },
          "country": {
            "type": "string",
            "maxLength": 50,
            "description": "Country. Updateable."
          },
          "npwp": {
            "type": ["string", "null"],
            "maxLength": 50,
            "description": "Tax ID / NPWP. Updateable."
          }
        },
        "required": [
          "uuid",
          "customerCode",
          "customerName",
          "address",
          "country"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "data"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "data": [
        {
          "uuid": "68078d50-24fb-4619-982b-c55e2b6c69e4",
          "customerCode": "CST001",
          "customerName": "Indonesian Armed Forces",
          "address": "Jl. Merdeka Barat No. 3, Gambir",
          "city": "Jakarta Pusat",
          "province": "DKI Jakarta",
          "country": "Indonesia",
          "npwp": "01.234.567.8-901.000"
        },
        {
          "uuid": "25586f08-785b-4901-9ef6-ac533072399e",
          "customerCode": "CST002",
          "customerName": "Indonesian National Police",
          "address": "Jl. Trunojoyo No. 3",
          "city": "Jakarta Selatan",
          "province": "DKI Jakarta",
          "country": "Indonesia",
          "npwp": null
        }
      ]
    }
  ]
}