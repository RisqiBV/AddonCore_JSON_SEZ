{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item Master PUT Schema",
  "description": "JSON contract for updating Item Master data by uuid. All fields should be sent with their current or updated values to maintain data consistency.",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "List of item master records to be updated.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Primary key for update. Required. System will update data only if uuid exists in database."
          },
          "itemCode": {
            "type": "string",
            "maxLength": 50,
            "description": "Unique item code. Not updateable, but must be sent with original value."
          },
          "itemName": {
            "type": "string",
            "maxLength": 250,
            "description": "Descriptive name of the item. Updateable."
          },
          "categoryCodeBC": {
            "type": "integer",
            "description": "INSW goods category code. Updateable. See ListOfCategoryBC.CategoryCode for reference."
          },
          "hsCode": {
            "type": ["string", "null"],
            "maxLength": 10,
            "description": "HS Code. Updateable. Can be null."
          },
          "categoryInternal": {
            "type": "string",
            "maxLength": 50,
            "description": "Internal classification or category. Updateable."
          }
        },
        "required": [
          "uuid",
          "itemCode",
          "itemName",
          "categoryCodeBC",
          "hsCode",
          "categoryInternal"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "data"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "data": [
        {
          "uuid": "aa9b1bcd-7a39-41ff-8cf9-4a57f9282988",
          "itemCode": "RAWMAT-01",
          "itemName": "Steel Plate 2 mm - Updated",
          "categoryCodeBC": 1,
          "hsCode": "58041011",
          "categoryInternal": "RawMaterial"
        },
        {
          "uuid": "0bc4ce79-7050-4d92-89ea-c3f151629715",
          "itemCode": "RAWMAT-02",
          "itemName": "Bending Machine Type X",
          "categoryCodeBC": 5,
          "hsCode": "58031011",
          "categoryInternal": "Machine"
        }
      ]
    }
  ]
}