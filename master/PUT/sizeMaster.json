{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Size Master PUT Schema",
  "description": "JSON contract for updating Size Master data by uuid. All fields should be sent with their current or updated values to maintain data consistency.",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "List of size master records to be updated.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Primary key for update. Required. System will update data only if uuid exists in database."
          },
          "sizeCode": {
            "type": "string",
            "maxLength": 10,
            "description": "Size code. Not updateable, but must be sent with original value."
          },
          "sizeDescription": {
            "type": "string",
            "maxLength": 50,
            "description": "Description of the size. Updateable."
          }
        },
        "required": [
          "uuid",
          "sizeCode",
          "sizeDescription"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "data"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "data": [
        {
          "uuid": "5f44ae17-cb26-4444-a398-3d12b8eb8f75",
          "sizeCode": "3XL",
          "sizeDescription": "Extra Extra Extra Large"
        },
        {
          "uuid": "bfe8e12b-5e09-4144-ac8c-535469789bda",
          "sizeCode": "4XL",
          "sizeDescription": "Super Jumbo Size"
        }
      ]
    }
  ]
}